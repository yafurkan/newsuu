# Firebase Configuration - PRODUCTION
# GERÇEK API ANAHTARLARINIZI BURAYA EKLEYİN
FIREBASE_API_KEY_WEB=your_firebase_api_key_web_here
FIREBASE_APP_ID_WEB=your_firebase_app_id_web_here
FIREBASE_MESSAGING_SENDER_ID_WEB=your_messaging_sender_id_here
FIREBASE_PROJECT_ID_WEB=your_project_id_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Firebase Configuration - ANDROID
FIREBASE_API_KEY_ANDROID=your_firebase_api_key_android_here
FIREBASE_APP_ID_ANDROID=your_firebase_app_id_android_here
FIREBASE_MESSAGING_SENDER_ID_ANDROID=your_messaging_sender_id_android_here
FIREBASE_PROJECT_ID_ANDROID=your_project_id_android_here
FIREBASE_STORAGE_BUCKET_ANDROID=your_project_id_android.firebasestorage.app

# Firebase Configuration - iOS
FIREBASE_API_KEY_IOS=your_firebase_api_key_ios_here
FIREBASE_APP_ID_IOS=your_firebase_app_id_ios_here
FIREBASE_MESSAGING_SENDER_ID_IOS=your_messaging_sender_id_ios_here
FIREBASE_PROJECT_ID_IOS=your_project_id_ios_here
FIREBASE_STORAGE_BUCKET_IOS=your_project_id_ios.appspot.com
FIREBASE_IOS_BUNDLE_ID=com.example.suu

# Development/Test Environment
NODE_ENV=production
DEBUG_MODE=false

# API Keys (Gerçek anahtarlarınızı buraya ekleyin)
# WEATHER_API_KEY=your_weather_api_key_here
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# KULLANIM TALİMATI:
# 1. Bu dosyayı .env olarak kopyalayın
# 2. Gerçek API anahtarlarınızı Firebase Console'dan alın
# 3. "your_*_here" kısımlarını gerçek değerlerle değiştirin
# 4. .env dosyası asla Git'e commit edilmemelidir!